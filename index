            });
          });
          const al = document.createElement('span'); al.className = 'al'; al.textContent = AULAS_PACOTE[fi][di] + ' aulas';
          realTd.appendChild(inp); realTd.appendChild(al); row.appendChild(realTd);
          const rTd = document.createElement('td'); rTd.className = 'risc'; rTd.id = 'ar-' + key;
          rTd.textContent = pre ? 'R$' + Math.round(pre * 1.3) : '—'; row.appendChild(rTd);
        });
        tbody.appendChild(row);
      });
    });
  });
  MIRRORS.forEach(m => {
    FREQS.forEach((_, fi) => { DURACOES.forEach((_, di) => {
      const fk = `${m.from[0]}-${m.from[1]}-${fi}-${di}`, tk = `${m.to[0]}-${m.to[1]}-${fi}-${di}`;
      const fe = document.getElementById('adm-' + fk), te = document.getElementById('adm-' + tk);
      if (fe && te && fe.value && !te.value) { te.value = fe.value; const v = parseFloat(fe.value)||0; document.getElementById('ar-'+tk).textContent = v ? 'R$'+Math.round(v*1.3) : '—'; }
    }); });
  });
}

function saveAdmin() {
  IDIOMAS.forEach((_, ii) => { _.pacotes.forEach((_, pi) => { FREQS.forEach((_, fi) => { DURACOES.forEach((_, di) => {
    const key = `${ii}-${pi}-${fi}-${di}`;
    const inp = document.getElementById('adm-' + key);
    if (inp) PRICES[key] = parseFloat(inp.value) || 0;
  }); }); }); });
  MESES.forEach((_, i) => {
    ['titulo','bonus'].forEach(tipo => {
      const el = document.getElementById(`promo-${tipo}-${i}`);
      if (el) PROMO_DATA[i][tipo] = el.value;
    });
  });
  render();
  const ok = document.getElementById('save-ok');
  ok.style.opacity = '1'; setTimeout(() => ok.style.opacity = '0', 2500);
}

buildPromoFields();
buildAdmin();
render();
</script>
