      <button class="copy-btn" onclick="copyMsg('main')">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.558 4.142 1.535 5.9L.057 23.57a.75.75 0 00.906.919l5.857-1.53A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.907 0-3.699-.504-5.25-1.385l-.372-.213-3.844 1.004 1.026-3.733-.232-.381A9.956 9.956 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
        Copiar Recomendação
      </button>
      <hr class="divider">
      <div class="section-title">Mensagem 2 - detalhes</div>
      <div class="msg-preview" id="details-preview"></div>
      <button class="copy-btn" onclick="copyMsg('details')">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.558 4.142 1.535 5.9L.057 23.57a.75.75 0 00.906.919l5.857-1.53A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.907 0-3.699-.504-5.25-1.385l-.372-.213-3.844 1.004 1.026-3.733-.232-.381A9.956 9.956 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
        Copiar Detalhes
      </button>
      <div class="copied" id="copied-msg">✓ Copiado!</div>
    </div>
    <div class="preview-card">
      <div class="pre-title">Prévia dos pacotes</div>
      <div id="result-plans"></div>
    </div>
  </div>
</div>

<!-- ADMIN (oculto) -->
<div id="tab-admin" class="tab-content">
  <div class="admin-content">
    <button class="save-btn" onclick="saveAdmin()">💾 Salvar alterações</button>
    <span class="save-ok" id="save-ok">✓ Salvo!</span>
    <div class="promo-card">
      <h3>🎁 Promos e Bônus por Mês</h3>
      <div id="promo-fields"></div>
    </div>
    <div class="admin-wrap">
      <table>
        <thead>
          <tr>
            <th class="left" rowspan="2">Idioma / Pacote</th>
            <th class="left" rowspan="2">Freq.</th>
