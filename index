<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Escolhedor de Preços — Idioma Independente</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'Segoe UI', Arial, sans-serif; background: #eef2f8; min-height: 100vh; }

.tabs { display: flex; background: #1a3a7a; }
.tab-btn { flex: 1; padding: 14px; color: rgba(255,255,255,0.6); font-size: 13px; font-weight: 600; border: none; background: none; cursor: pointer; border-bottom: 3px solid transparent; transition: all 0.2s; }
.tab-btn.active { color: #fff; border-bottom-color: #cc2222; }

.tab-content { display: none; padding: 1.25rem 1rem 2rem; max-width: 1100px; margin: 0 auto; }
.tab-content.active { display: block; }
#tab-escolhedor.active { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; align-items: start; }
#tab-escolhedor .col-left { min-width: 0; }
#tab-escolhedor .col-right { min-width: 0; position: sticky; top: 1rem; }
@media (max-width: 700px) {
  #tab-escolhedor.active { display: block; }
  #tab-escolhedor .col-right { position: static; }
}

.logo { text-align: center; margin-bottom: 1rem; }
.logo h1 { font-size: 1.4rem; font-weight: 700; color: #1a3a7a; }
.logo span { color: #cc2222; }
.logo p { font-size: 0.75rem; color: #5a6a8a; margin-top: 3px; letter-spacing: 1px; text-transform: uppercase; }

.instructions { background: #fff; border-radius: 12px; border-left: 4px solid #1a3a7a; padding: 1rem 1.25rem; margin-bottom: 1.25rem; box-shadow: 0 2px 10px rgba(26,58,122,0.07); }
.instructions h3 { font-size: 0.72rem; font-weight: 700; color: #1a3a7a; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.6rem; }
.instructions ol { padding-left: 1.1rem; }
.instructions li { font-size: 0.8rem; color: #3a4a6a; line-height: 1.6; margin-bottom: 3px; }
.instructions li strong { color: #1a3a7a; }

.card { background: #fff; border-radius: 14px; box-shadow: 0 4px 20px rgba(26,58,122,0.09); padding: 1.25rem; margin-bottom: 1rem; }
.section-title { font-size: 0.68rem; font-weight: 700; color: #1a3a7a; text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 0.65rem; }
.toggle-group { display: flex; gap: 6px; flex-wrap: wrap; }
.toggle-btn { flex: 1; min-width: 70px; padding: 8px 6px; border: 1.5px solid #d0d8e8; border-radius: 9px; background: #f5f8ff; color: #5a6a8a; font-size: 0.77rem; font-weight: 600; cursor: pointer; text-align: center; transition: all 0.18s; line-height: 1.3; }
.toggle-btn.active { background: #1a3a7a; color: #fff; border-color: #1a3a7a; }
.toggle-btn.active.red { background: #cc2222; border-color: #cc2222; }
.divider { border: none; border-top: 1px solid #eef2f8; margin: 1rem 0; }

#cupom-input, #lead-context, #lead-name { width: 100%; padding: 9px 14px; border: 1.5px solid #d0d8e8; border-radius: 9px; font-size: 0.9rem; color: #1a3a7a; background: #f5f8ff; outline: none; margin-top: 8px; font-family: inherit; }
#cupom-input:focus, #lead-context:focus, #lead-name:focus { border-color: #1a3a7a; }
#lead-context { min-height: 62px; resize: vertical; line-height: 1.4; }
.field-hint { color: #5a6a8a; font-size: 0.72rem; line-height: 1.4; margin-top: 6px; }
.chooser-section.hidden { display: none; }
.mode-highlight { background: #f7f9fe; border: 1.5px solid #dce5f6; border-radius: 12px; padding: 0.95rem; margin-bottom: 1rem; }
.mode-highlight .section-title { margin-bottom: 0.75rem; }
#cupom-aviso { display: none; color: #cc2222; font-size: 0.75rem; font-weight: 600; margin-top: 5px; }

.msg-preview { background: #f5f8ff; border-radius: 9px; padding: 1rem; font-size: 0.8rem; color: #1a3a7a; white-space: pre-wrap; line-height: 1.65; border: 1.5px solid #d0d8e8; max-height: 420px; overflow-y: auto; }
.copy-btn { margin-top: 0.75rem; width: 100%; padding: 13px; background: #25D366; color: #fff; border: none; border-radius: 9px; font-size: 1rem; font-weight: 700; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; }
.copy-btn:hover { opacity: 0.88; }
.copied { text-align: center; font-size: 0.78rem; color: #25D366; font-weight: 600; margin-top: 6px; opacity: 0; transition: opacity 0.3s; }

.preview-card { background: #1a3a7a; border-radius: 13px; padding: 1.1rem; color: #fff; }
.pre-title { font-size: 0.65rem; font-weight: 700; opacity: 0.6; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; }
.plan-row { background: rgba(255,255,255,0.1); border-radius: 8px; padding: 9px 12px; margin-bottom: 6px; }
.plan-row.best { background: rgba(255,255,255,0.18); border: 1px solid rgba(255,255,255,0.3); }
.plan-row.warn { background: rgba(204,34,34,0.15); border: 1px solid rgba(204,34,34,0.3); }
.plan-title { font-size: 0.7rem; font-weight: 700; opacity: 0.85; margin-bottom: 4px; text-transform: uppercase; }
.plan-line { font-size: 0.78rem; opacity: 0.9; padding: 1px 0; }
.best-badge { display: inline-block; background: #cc2222; color: #fff; font-size: 0.6rem; font-weight: 700; padding: 1px 6px; border-radius: 20px; margin-left: 4px; vertical-align: middle; }
.warn-text { font-size: 0.7rem; opacity: 0.8; margin-top: 5px; padding-top: 5px; border-top: 1px solid rgba(255,255,255,0.15); font-style: italic; }

/* ADMIN */
.admin-content { max-width: 960px; margin: 0 auto; padding: 1.25rem 1rem 2rem; }
.admin-wrap { overflow-x: auto; }
table { border-collapse: collapse; width: 100%; background: #fff; border-radius: 12px; overflow: hidden; box-shadow: 0 2px 12px rgba(26,58,122,0.08); margin-bottom: 1.5rem; font-size: 12px; }
th { background: #1a3a7a; color: #fff; padding: 9px 10px; text-align: center; font-size: 11px; font-weight: 600; }
th.left { text-align: left; }
td { padding: 6px 9px; border-bottom: 1px solid #eef2f8; text-align: center; color: #1a3a7a; vertical-align: middle; }
td.lbl { text-align: left; font-weight: 600; background: #f5f8ff; white-space: pre-line; }
td.sub { text-align: left; color: #5a6a8a; background: #f9fbff; padding-left: 14px; font-size: 11px; }
td input.val { width: 64px; padding: 3px 5px; border: 1.5px solid #d0d8e8; border-radius: 5px; font-size: 11px; color: #1a3a7a; text-align: center; background: #fff; display: block; margin: 0 auto 2px; }
td input.val:focus { border-color: #1a3a7a; outline: none; }
td input.val.mirrored { background: #f0f4ff; color: #7a8abf; border-color: #b0bcdf; }
td .al { font-size: 9px; color: #9aaac8; display: block; }
td.risc { color: #999; font-size: 10px; }
tr.gh td { background: #1a3a7a; color: #fff; font-weight: 700; font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; cursor: pointer; user-select: none; padding: 9px 13px; }
tr.gh td:hover { background: #15306a; }
tr.collapsed { display: none; }
.save-btn { padding: 10px 22px; background: #1a3a7a; color: #fff; border: none; border-radius: 8px; font-size: 13px; font-weight: 600; cursor: pointer; margin-bottom: 1rem; }
.save-btn:hover { opacity: 0.88; }
.save-ok { font-size: 12px; color: #25D366; font-weight: 600; margin-left: 10px; opacity: 0; transition: opacity 0.3s; }
.promo-card { background: #fff; border-radius: 12px; box-shadow: 0 2px 12px rgba(26,58,122,0.08); padding: 1.25rem; margin-bottom: 1rem; }
.promo-card h3 { font-size: 12px; font-weight: 700; color: #1a3a7a; margin-bottom: 0.75rem; text-transform: uppercase; letter-spacing: 1px; }
.promo-row { display: grid; grid-template-columns: 80px 1fr; gap: 8px; align-items: start; margin-bottom: 8px; }
.promo-row label { font-size: 11px; font-weight: 600; color: #5a6a8a; padding-top: 6px; }
.promo-row textarea { width: 100%; padding: 6px 9px; border: 1.5px solid #d0d8e8; border-radius: 7px; font-size: 11px; color: #1a3a7a; resize: vertical; min-height: 48px; font-family: inherit; }
.promo-row textarea:focus { border-color: #1a3a7a; outline: none; }

/* Admin access */
.admin-access { text-align: right; padding: 4px 12px; background: #1a3a7a; }
.admin-access a { font-size: 11px; color: rgba(255,255,255,0.3); text-decoration: none; cursor: pointer; }
.admin-access a:hover { color: rgba(255,255,255,0.7); }
</style>
</head>
<body>

<div class="admin-access"><a onclick="toggleAdmin()">⚙️ admin</a></div>

<div id="tab-escolhedor" class="tab-content active">
  <div class="col-left">
    <div class="logo">
      <h1>Idioma <span>Independente</span></h1>
      <p>Escolhedor de Preços</p>
    </div>
    <div class="instructions">
      <h3>📋 Como usar</h3>
      <ol>
        <li>Selecione todos os quadrados de acordo com o valor a ser enviado.</li>
        <li>Clique em <strong>Influencer</strong> e adicione o cupom referente ao cadastro dele.</li>
        <li>Clique em <strong>Copiar Mensagem para WhatsApp</strong> e envie os valores para o lead.</li>
      </ol>
    </div>
    <div class="card">
      <div class="mode-highlight">
        <div class="section-title">Tipo de escolhedor</div>
        <div class="toggle-group" id="modo-group">
          <button class="toggle-btn active" data-val="perfil">Separar por Perfil/objetivo do lead</button>
          <button class="toggle-btn" data-val="pacotes">Separar por pacotes</button>
        </div>
      </div>
      <div class="section-title">Idioma</div>
      <div class="toggle-group" id="idioma-group">
        <button class="toggle-btn active" data-ii="0" data-emoji="🇺🇸🇬🇧" data-label="Inglês">🇺🇸 Inglês</button>
        <button class="toggle-btn" data-ii="0" data-emoji="🇪🇸🇲🇽" data-label="Espanhol">🇪🇸 Espanhol</button>
        <button class="toggle-btn" data-ii="1" data-emoji="🇫🇷" data-label="Francês">🇫🇷 Francês</button>
        <button class="toggle-btn" data-ii="2" data-emoji="🇩🇪" data-label="Alemão">🇩🇪 Alemão</button>
        <button class="toggle-btn" data-ii="2" data-emoji="🇮🇹" data-label="Italiano">🇮🇹 Italiano</button>
        <button class="toggle-btn" data-ii="2" data-emoji="🌍" data-label="Outro idioma">🌍 Outros</button>
      </div>
      <div id="tipo-section" class="chooser-section hidden">
        <hr class="divider">
        <div class="section-title">Tipo de curso</div>
        <div class="toggle-group" id="tipo-group">
          <button class="toggle-btn active" data-pi="0" data-emoji="📚" data-label="Normal">📚 Normal</button>
          <button class="toggle-btn" data-pi="1" data-emoji="💼" data-label="Business">💼 Business</button>
          <button class="toggle-btn" data-pi="1" data-emoji="👦" data-label="Kids & Teens">👦 Kids & Teens</button>
          <button class="toggle-btn red" data-pi="2" data-emoji="🎓" data-label="Prova de Proficiência" id="btn-prof">🎓 Prova de Proficiência</button>
        </div>
      </div>
      <hr class="divider">
      <div class="section-title">Turma</div>
      <div class="toggle-group" id="turma-group">
        <button class="toggle-btn active" data-mt="1" data-label="Particular">Particular</button>
        <button class="toggle-btn" data-mt="0.75" data-label="Dupla">Dupla</button>
        <button class="toggle-btn" data-mt="0.66" data-label="Trio">Trio</button>
        <button class="toggle-btn" data-mt="0.56" data-label="Quarteto">Quarteto</button>
        <button class="toggle-btn" data-mt="0.5" data-label="Cinco+">Cinco+</button>
      </div>
      <hr class="divider">
      <div class="section-title">Cupom</div>
      <div class="toggle-group" id="cupom-group">
        <button class="toggle-btn" data-val="indicacao">Cupom INDICAÇÃO</button>
        <button class="toggle-btn active" data-val="influencer">Influencer</button>
        <button class="toggle-btn" data-val="sem_desconto">Lead não confirmou<br><small style="font-size:0.65rem">Só valores riscados</small></button>
      </div>
      <div id="cupom-input-wrap">
        <input type="text" id="cupom-input" placeholder="Digite o cupom do influencer..." />
        <div id="cupom-aviso">⚠️ INSIRA O CUPOM DO INFLUENCER</div>
      </div>
      <hr class="divider">
      <div class="section-title">Horário</div>
      <div class="toggle-group" id="horario-group">
        <button class="toggle-btn active" data-val="0">🕐 Horários Comuns<br><small style="font-size:0.68rem;font-weight:400">9h – 17h</small></button>
        <button class="toggle-btn" data-val="20">⭐ Prime Time<br><small style="font-size:0.68rem;font-weight:400">7h/8h, 18h–22h e Fim de Semana</small></button>
      </div>
      <hr class="divider">
      <div class="section-title">Nome do lead</div>
      <input type="text" id="lead-name" placeholder="Ex.: Maria" />
      <hr class="divider">
      <div id="perfil-section" class="chooser-section">
        <div class="section-title">Perfil / Objetivo do lead</div>
        <div class="toggle-group" id="perfil-group">
          <button class="toggle-btn active" data-val="iniciante">Iniciante ou travado</button>
          <button class="toggle-btn" data-val="intermediario">Intermediário</button>
          <button class="toggle-btn" data-val="avancado">Avançado</button>
          <button class="toggle-btn" data-val="fluencia">Quer fluência</button>
          <button class="toggle-btn" data-val="preco">Preço baixo</button>
          <button class="toggle-btn" data-val="urgencia">Urgência</button>
        </div>
      </div>
      <textarea id="lead-context" placeholder="Ex.: quer sair do básico, tem vergonha de falar e consegue estudar 1x por semana"></textarea>
      <div class="field-hint">Vai aparecer como o objetivo que o lead passou.</div>
      <hr class="divider">
      <div id="pacotes-section" class="chooser-section hidden">
        <div class="section-title">Pacotes a exibir</div>
        <div class="toggle-group" id="pacotes-group">
          <button class="toggle-btn active" data-val="main">1, 2 e 3 anos</button>
          <button class="toggle-btn" data-val="all">Incluir 6 meses ⚠️ só avançados</button>
        </div>
        <hr class="divider">
        <div class="section-title">Frequência na mensagem</div>
        <div class="toggle-group" id="freq-group">
          <button class="toggle-btn active" data-val="12">1x e 2x na semana</button>
          <button class="toggle-btn" data-val="123">Incluir 3x na semana</button>
          <button class="toggle-btn" data-val="345">Intensivos<br><small style="font-size:0.65rem">3x, 4x e 5x na semana</small></button>
        </div>
      </div>
    </div>
  </div>

  <div class="col-right">
    <div class="card">
      <div class="section-title">Mensagem 1 - recomendação</div>
