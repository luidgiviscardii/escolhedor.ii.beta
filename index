function smartRound(val) {
  if (val <= 0) return 0;
  const r = Math.round(val);
  const floor10 = Math.floor(r / 10) * 10;
  const candidates = [floor10 - 3, floor10 + 2, floor10 + 7, floor10 + 12].filter(v => v > 0);
  return candidates.reduce((best, v) => Math.abs(v - r) < Math.abs(best - r) ? v : best, candidates[0]);
}
function fmtBRL(v) { return 'R$ ' + v.toLocaleString('pt-BR'); }
function getPrice(ii, pi, fi, di) { return PRICES[`${ii}-${pi}-${fi}-${di}`] || 0; }
function getCourseTypeIndex() {
  if (state.modo === 'perfil') return state.perfil === 'avancado' ? 1 : 0;
  return state.pi;
}
function applyTurma(base) {
  const v = state.mt === 1 ? base : smartRound(base * state.mt);
  return v + state.horario;
}
function getFreqs() {
  if (state.fq === '12') return [0,1];
  if (state.fq === '123') return [0,1,2];
  return [2,3,4];
}
function planByDi(di) { return PLAN_META.find(p => p.di === di); }
function freqText(fi) {
  return ['uma vez na semana', 'duas vezes na semana', 'três vezes na semana', 'quatro vezes na semana', 'cinco vezes na semana'][fi] || `${fi+1}x na semana`;
}
function getOfferOptions(rec, limit = 4) {
  const options = [];
  const planIds = rec.plans.filter(di => planByDi(di));
  const freqIds = rec.freqs;
  const add = (di, fi) => {
    if (options.some(o => o.di === di && o.fi === fi)) return;
    const plan = planByDi(di);
    const base = getPrice(state.ii, getCourseTypeIndex(), fi, di);
    if (!plan || !base) return;
    const real = applyTurma(base);
    options.push({
      di, fi, plan, real,
      risc: Math.round(real * 1.3),
      role: rec.roles[di] || (di === rec.mainDi ? 'Minha sugestão' : 'Outra opção')
    });
  };

  planIds.forEach(di => add(di, freqIds[0]));
  if (freqIds.length > 1) planIds.forEach(di => add(di, freqIds[1]));
  for (let i = 2; i < freqIds.length; i++) planIds.forEach(di => add(di, freqIds[i]));
  return options.slice(0, limit);
}
